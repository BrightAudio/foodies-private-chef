# Environment Variables for Foodies
# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────
# Local development (SQLite):
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL — use Neon, Supabase, or Vercel Postgres):
# DATABASE_URL="postgresql://user:password@host:5432/foodies?sslmode=require"

# ─── Auth ────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-secure-random-string-in-production"

# ─── PII Encryption (AES-256-GCM) ───────────────────────────────
ENCRYPTION_KEY="change-this-to-a-secure-random-string-in-production"

# ─── App ─────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=30
CLIENT_SERVICE_FEE_PERCENT=8
NEXT_PUBLIC_APP_NAME="Foodies"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Stripe (optional — leave blank to disable) ─────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_IDENTITY_WEBHOOK_SECRET=

# ─── Checkr (optional — leave blank for manual BG checks) ───────
CHECKR_API_KEY=
CHECKR_API_URL=https://api.checkr.com/v1
CHECKR_WEBHOOK_SECRET=

# ─── S3 / Image Storage (optional — local fallback in dev) ──────
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─── Redis (optional — in-memory fallback if blank) ─────────────
REDIS_URL=

# ─── Email / SMTP (optional — leave blank to log to console) ────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Foodies <noreply@foodies.com>"
