# Environment Variables for Foodies
# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────
# Local development (SQLite):
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL — use Neon, Supabase, or Vercel Postgres):
# DATABASE_URL="postgresql://user:password@host:5432/foodies?sslmode=require"

# ─── Auth ────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-secure-random-string-in-production"

# ─── App ─────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=30
NEXT_PUBLIC_APP_NAME="Foodies"

# ─── Stripe (optional — leave blank to disable) ─────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email / SMTP (optional — leave blank to log to console) ────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Foodies <noreply@foodies.com>"
